# ============================================
# SUPABASE CONFIGURATION
# Get from: Supabase Dashboard → Settings → API
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# ADMIN CREDENTIALS
# Choose secure username and password
# ============================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_secure_password_here

# ============================================
# CLOUDFLARE TURNSTILE
# Get from: Cloudflare Dashboard → Turnstile
# ============================================
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ============================================
# SESSION CONFIGURATION
# For JWT signing, generate: openssl rand -base64 32
# ============================================
SESSION_SECRET=your_session_secret_generated_value_here

# ============================================
# APPLICATION CONFIGURATION
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
# For Vercel: NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
